#!name=NovixLink VPS 流量
#!desc=通过 AnyTLS 节点读取 VPS 本地统计，显示收发流量、套餐余量、重置时间和运行时长。
#!arguments=POLICY:NovixLink-AnyTLS
#!requirement=CORE_VERSION>=20

[Panel]
NovixLink Traffic = title="NovixLink VPS",content="点击刷新以查询流量",style=info,script-name=novixlink-traffic,update-interval=600

[Script]
novixlink-traffic = type=generic,script-path=https://raw.githubusercontent.com/succichang/surge-bandwagon-traffic/main/NovixLink-Traffic.js,argument="POLICY={{{POLICY}}}",timeout=10
